#!/usr/bin/env bash

# Add user gem bin to PATH (for gem install --user-install)
export PATH="$HOME/.local/share/gem/ruby/$(ruby -e 'puts RUBY_VERSION[/\d+\.\d+/]').0/bin:$HOME/.rbenv/shims:$PATH"

if ! command -v foreman &> /dev/null; then
  echo "Installing foreman..."
  gem install foreman --no-document
fi

exec foreman start -f Procfile.dev "$@"
